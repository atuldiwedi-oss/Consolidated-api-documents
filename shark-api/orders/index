    <span class="k">if</span><span class="p">(</span><span class="n">quantity</span><span class="p">)</span> <span class="p">:</span>
      <span class="n">params</span><span class="p">[</span><span class="s">'quantity'</span><span class="p">]</span> <span class="o">=</span> <span class="nb">int</span><span class="p">(</span><span class="n">quantity</span><span class="p">)</span>
    <span class="k">if</span><span class="p">(</span><span class="n">stop_price</span><span class="p">)</span> <span class="p">:</span>
